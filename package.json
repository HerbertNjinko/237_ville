{
  "name": "237-ville",
  "version": "0.1.0",
  "description": "Community organization platform for 237 Ville members, voting, announcements, events, dues, and donations.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.js",
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
