PORT=4173
APP_URL=https://organization237.njinkofarm.com
PGDATABASE=organization_237
SESSION_SECRET=replace-with-a-long-random-secret

# Optional. If set, this takes precedence over PGDATABASE/PGUSER/PGHOST/PGPORT.
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/organization_237

# Bootstrap admin account used by npm run seed.
ADMIN_EMAIL=admin@237ville.org
ADMIN_PASSWORD=ChangeMe237!
ADMIN_NAME=237 Ville Admin
ADMIN_FIRST_NAME=237
ADMIN_LAST_NAME=Ville Admin

# Registration onboarding
REGISTRATION_FEE_CENTS=5000
POLICY_TITLE=237 Ville Member Policy
POLICY_VERSION=2026-05-06

# SMTP email alerts
# SMTP is considered enabled when SMTP_HOST is set, or when SMTP_ENABLED=true.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=237 Ville
SMTP_REPLY_TO=

# Dwolla sandbox donations
DWOLLA_ENABLED=false
DWOLLA_ENVIRONMENT=sandbox
DWOLLA_KEY=
DWOLLA_SECRET=
DWOLLA_WEBHOOK_SECRET=
DWOLLA_COMPANY_FUNDING_SOURCE_URL=
